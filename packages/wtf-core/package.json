{
  "name": "@igouss/wtf-core",
  "version": "0.1.0",
  "description": "WTF orchestration core — harness-agnostic task execution engine",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/igouss/wtf-3.git",
    "directory": "packages/wtf-core"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./dist/*": "./dist/*",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc && cp -r src/templates dist/templates && cp -r src/prompts dist/prompts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "yaml": "^2.8.2",
    "proper-lockfile": "^4.1.2"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "@types/proper-lockfile": "^4.1.4",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*"
  ]
}
