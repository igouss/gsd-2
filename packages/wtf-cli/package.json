{
  "name": "@igouss/wtf-cli",
  "version": "0.1.0",
  "description": "WTF standalone CLI — runs WTF orchestrator with Claude Code or any harness",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/igouss/wtf-3.git",
    "directory": "packages/wtf-cli"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "wtf-run": "./dist/run.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@igouss/wtf-core": "^0.1.0",
    "@igouss/wtf-tui": "^0.1.0",
    "@igouss/mcp-server": "^2.52.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*"
  ]
}
